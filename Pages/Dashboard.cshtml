@page
@model QueryBot.Pages.DashboardModel
@{
    Layout = null;
}
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>queryBot — Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="~/styles.css" />
</head>
<body>
  <div class="page-shell dashboard-shell">
    <div class="blob blob-left"></div>
    <div class="blob blob-right"></div>

    <header class="topbar">
      <a class="brand" href="/Dashboard">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 16c0-5.5 4.5-10 10-10h28c3.2 0 5.8 2.6 5.8 5.8v21.9c0 3.2-2.6 5.8-5.8 5.8H27L16 50.2c-2.5 2.4-6.6.6-6.6-2.9v-9.9A9.8 9.8 0 0 1 4 28.9V16h6z" fill="#ff8b18" />
            <path d="M20 17h21" stroke="#fff" stroke-width="4.4" stroke-linecap="round" />
            <path d="M20 26h17" stroke="#fff" stroke-width="4.4" stroke-linecap="round" />
            <path d="M20 35h13" stroke="#fff" stroke-width="4.4" stroke-linecap="round" />
          </svg>
        </span>
        <span class="brand-text"><span class="brand-dark">query</span><span class="brand-accent">Bot</span></span>
      </a>

      <nav class="nav">
        <form method="post" asp-page="/Account/Logout" class="nav-logout-form">
          <button type="submit" class="nav-logout-btn">Log Out</button>
        </form>
      </nav>
    </header>

    <main class="hero">
      <section class="hero-copy">
        <h1>
          From <span class="dark-keep">blank pages</span><br />
          to <span class="accent-script">polished responses</span>
        </h1>

        @if (Model.SuccessMessage is not null)
        {
          <div class="upload-feedback upload-success" role="status">@Model.SuccessMessage</div>
        }
        @if (Model.ErrorMessage is not null)
        {
          <div class="upload-feedback upload-error" role="alert">@Model.ErrorMessage</div>
        }

        <form method="post" enctype="multipart/form-data" asp-page-handler="Upload" id="uploadForm">
          <input type="file" name="Uploads" id="fileInput" style="display:none" multiple accept=".docx,.xlsx,.pdf,.txt" />

          <div class="upload-panel" id="dropZone">
            <p class="upload-desc">Upload documents containing model answers to train the AI to your specific requirements.</p>
            <p class="upload-drop-text">Drag and drop files here.</p>
            <p class="upload-or">Or</p>
            <button type="button" class="btn btn-upload" id="addFileBtn">Add files</button>
            <p class="upload-size-hint">Maximum file size: 3 MB per file. Accepted formats: .docx, .xlsx, .pdf, .txt</p>
            <p class="upload-drag-error" id="dragError" style="display:none" role="alert"></p>
          </div>
        </form>
      </section>

      <section class="hero-art" aria-hidden="true">
        <img src="~/assets/hero-right.png" alt="" />
      </section>
    </main>
  </div>

  <div class="modal-overlay" id="modalOverlay" style="display:none" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
    <div class="modal-dialog">
      <h2 class="modal-title" id="modalTitle">Add files</h2>
      <label class="modal-choose-label" for="modalFileInput">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M12 16V8M12 8L9 11M12 8L15 11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <rect x="3" y="3" width="18" height="18" rx="4" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        <span id="modalFileName">Choose files&hellip;</span>
      </label>
      <input type="file" id="modalFileInput" style="display:none" multiple accept=".docx,.xlsx,.pdf,.txt" />
      <p class="modal-size-note">Maximum file size: 3 MB per file. Accepted formats: .docx, .xlsx, .pdf, .txt</p>
      <p class="modal-error" id="modalError" style="display:none" role="alert"></p>
      <div class="modal-actions">
        <button type="button" class="modal-btn-cancel" id="cancelBtn">Cancel</button>
        <button type="button" class="modal-btn-upload" id="uploadBtn" disabled>Upload</button>
      </div>
    </div>
  </div>

  <script>
    (function () {
      var MAX     = 3 * 1024 * 1024;
      var ALLOWED = ['.docx', '.xlsx', '.pdf', '.txt'];

      var dropZone       = document.getElementById('dropZone');
      var fileInput      = document.getElementById('fileInput');
      var uploadForm     = document.getElementById('uploadForm');
      var addFileBtn     = document.getElementById('addFileBtn');
      var dragError      = document.getElementById('dragError');
      var modalOverlay   = document.getElementById('modalOverlay');
      var modalFileInput = document.getElementById('modalFileInput');
      var modalFileName  = document.getElementById('modalFileName');
      var modalError     = document.getElementById('modalError');
      var cancelBtn      = document.getElementById('cancelBtn');
      var uploadBtn      = document.getElementById('uploadBtn');

      addFileBtn.addEventListener('click', openModal);
      cancelBtn.addEventListener('click', closeModal);
      modalOverlay.addEventListener('click', function (e) {
        if (e.target === modalOverlay) closeModal();
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && modalOverlay.style.display !== 'none') closeModal();
      });

      function openModal() {
        modalFileInput.value = '';
        modalFileName.textContent = 'Choose files\u2026';
        modalError.style.display = 'none';
        uploadBtn.disabled = true;
        modalOverlay.style.display = 'flex';
      }

      function closeModal() {
        modalOverlay.style.display = 'none';
      }

      function isAllowedType(file) {
        var name = file.name.toLowerCase();
        return ALLOWED.some(function (ext) { return name.endsWith(ext); });
      }

      function validateFiles(files) {
        for (var i = 0; i < files.length; i++) {
          if (!isAllowedType(files[i])) {
            return '\u201c' + files[i].name + '\u201d is not an accepted file type.';
          }
          if (files[i].size > MAX) {
            return '\u201c' + files[i].name + '\u201d exceeds the 3 MB maximum.';
          }
        }
        return null;
      }

      modalFileInput.addEventListener('change', function () {
        var files = modalFileInput.files;
        if (!files || files.length === 0) { resetModal(); return; }
        var err = validateFiles(files);
        if (err) {
          modalError.textContent = err;
          modalError.style.display = 'block';
          modalFileName.textContent = 'Choose files\u2026';
          uploadBtn.disabled = true;
          return;
        }
        modalError.style.display = 'none';
        modalFileName.textContent = files.length === 1 ? files[0].name : files.length + ' files selected';
        uploadBtn.disabled = false;
      });

      function resetModal() {
        modalFileName.textContent = 'Choose files\u2026';
        modalError.style.display = 'none';
        uploadBtn.disabled = true;
      }

      uploadBtn.addEventListener('click', function () {
        var files = modalFileInput.files;
        if (!files || files.length === 0) return;
        transferAndSubmit(files);
      });

      // Drag and drop
      dropZone.addEventListener('dragover', function (e) {
        e.preventDefault();
        dropZone.classList.add('drop-hover');
      });

      dropZone.addEventListener('dragleave', function (e) {
        if (!dropZone.contains(e.relatedTarget)) {
          dropZone.classList.remove('drop-hover');
        }
      });

      dropZone.addEventListener('drop', function (e) {
        e.preventDefault();
        dropZone.classList.remove('drop-hover');
        var files = e.dataTransfer.files;
        if (files.length === 0) return;
        var err = validateFiles(files);
        if (err) {
          showDragError(err);
          return;
        }
        dragError.style.display = 'none';
        transferAndSubmit(files);
      });

      function showDragError(msg) {
        dragError.textContent = msg;
        dragError.style.display = 'block';
      }

      function transferAndSubmit(files) {
        var dt = new DataTransfer();
        for (var i = 0; i < files.length; i++) {
          dt.items.add(files[i]);
        }
        fileInput.files = dt.files;
        closeModal();
        uploadForm.submit();
      }
    })();
  </script>
</body>
</html>
